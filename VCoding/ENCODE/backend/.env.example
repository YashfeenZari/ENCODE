# Database (Aiven MySQL)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password

# Optional: single connection string instead of separate vars
# DATABASE_URL=mysql://user:pass@host:25060/defaultdb?ssl-mode=REQUIRED

# Auth
JWT_SECRET=your-long-random-secret-at-least-32-chars

# Server
PORT=5000
